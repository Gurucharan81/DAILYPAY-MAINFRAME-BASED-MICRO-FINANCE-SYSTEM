       IDENTIFICATION DIVISION.
       PROGRAM-ID. AGCTPROG.

       DATA DIVISION.

       WORKING-STORAGE SECTION.
       01 WS-COMMAREA PIC X(28).
       01 WS-ABSTIME PIC X(10).
       01 WS-DATE.
          05 DD PIC 99.
          05 A  PIC X VALUE '/'.
          05 MM PIC 99.
          05 B  PIC X VALUE '/'.
          05 YYYY PIC 9999.
       01 EOF PIC X VALUE 'N'.
       01 EOD PIC X VALUE 'N'.
       01 WS-TSQ-NAME        PIC X(10) VALUE 'DAYTARGETS'.
       01 WS-RESP            PIC S9(8) COMP.
       01 WS-I               PIC S9(4) COMP.
       01 WS-TEMP-INDEX      PIC S9(4) COMP.
       01 WS-TOTAL-TARGET    PIC 9(9) VALUE 0.
       01 WS-TOTAL-COLLECTED PIC 9(9) VALUE 0.
       01 LOAN-REC.
          05 LOAN-ID PIC X(6).
          05 CUST-ID PIC X(5).
          05 NAME    PIC X(10).
          05 STATUS1 PIC X(08).
          05 ACTAMT PIC 9(6).
          05 REAT    PIC X(45) VALUE SPACES.
       01 WS-REC.
          05 WS-LOANID       PIC X(6).
          05 WS-CUSTID       PIC X(5).
          05 WS-NAME         PIC X(10).
          05 WS-STATUS       PIC X(8).
          05 WS-ACTAMT       PIC 9(6).
          05 WS-AMTPAID      PIC 9(6).
       01 WS-OUT-REC.
          05 O-TRANSID       PIC X(11).
          05 O-LOANID        PIC X(6).
          05 O-CUSTID        PIC X(5).
          05 O-NAME          PIC X(10).
          05 O-STATUS        PIC X(8).
          05 O-ACTAMT        PIC 9(6).
          05 O-PAID          PIC 9(6).
          05 O-PTYPE         PIC X.
          05 O-YORN          PIC X.
          05 BEAT            PIC X(26).
       01 AG-REC.
          05 AG-SCREEN PIC X.
          05 AG-AGENTID PIC X(5).
       01 WS-COUNT          PIC 999.
      *----------------------------------------------------------------*
             COPY AGCT.
             COPY DFHAID.
      *----------------------------------------------------------------*

      *----------------------------------------------------------------*
      * COMMAREA
      *----------------------------------------------------------------*
       LINKAGE SECTION.
       01 DFHCOMMAREA.
          05 CA-SCREEN       PIC X.
          05 CA-AGENTID      PIC 9(5).
          05 CA-INDEX        PIC 9(4).
          05 CA-TOTAL        PIC 9(4).
          05 CA-TOTAL-TARGET     PIC 9(9).
          05 CA-TOTAL-COLLECTED  PIC 9(9).
       PROCEDURE DIVISION.
       MAIN-PARA.
           IF EIBCALEN = 0
              MOVE LOW-VALUES TO AGCTO
      *       MOVE CA-AGENTID TO AGENTIDO
              PERFORM LOAD-TSQ
              PERFORM DISPLAY-PARA
              EXEC CICS RETURN
                   TRANSID('TACT')
                   COMMAREA(WS-COMMAREA)
                   LENGTH(LENGTH OF WS-COMMAREA)
              END-EXEC
           ELSE
              MOVE 1 TO CA-INDEX
              MOVE 0 TO CA-TOTAL-COLLECTED
              MOVE 'Y' TO CA-SCREEN
           IF CA-SCREEN = 'X'
              MOVE 'Y' TO CA-SCREEN
              MOVE 0 TO CA-TOTAL-COLLECTED
              MOVE LOW-VALUES TO AGCTO
              MOVE CA-AGENTID TO AGENTIDO
              PERFORM LOAD-TSQ
              PERFORM DISPLAY-PARA
              EXEC CICS RETURN
                   TRANSID('TACT')
                   COMMAREA(WS-COUNT)
                   LENGTH(3)
              END-EXEC
              CONTINUE
           ELSE
              MOVE 1 TO CA-INDEX
              MOVE CA-AGENTID TO AGENTIDO
           EVALUATE EIBAID

              WHEN DFHENTER
                   PERFORM RECEIVE-PARA
                   PERFORM SAVE-DATA
                   EXEC CICS SEND MAP('AGCT') MAPSET('AGCT')
                   END-EXEC
                   EXEC CICS RETURN
                             TRANSID('TACT')
                             COMMAREA(DFHCOMMAREA)
                             LENGTH(LENGTH OF DFHCOMMAREA)
                   END-EXEC
                   CONTINUE
              WHEN DFHPF8
                   PERFORM NEXT-PAGE
                   PERFORM DISPLAY-PARA
              WHEN DFHPF7
                   PERFORM PREV-PAGE
                   PERFORM DISPLAY-PARA
              WHEN DFHPF3
                 MOVE 'X' TO AG-SCREEN
                 MOVE CA-AGENTID TO AG-AGENTID
                 EXEC CICS XCTL PROGRAM('PAGMU')
                 END-EXEC
      *                    COMMAREA(AG-REC)
      *                    LENGTH(LENGTH OF AG-REC)
           END-EVALUATE



           EXEC CICS RETURN
                TRANSID('TACT')
                COMMAREA(DFHCOMMAREA)
                LENGTH(LENGTH OF DFHCOMMAREA)
           END-EXEC
           END-IF.
       RECEIVE-PARA.
            EXEC CICS RECEIVE MAP('AGCT')
                              MAPSET('AGCT')
            END-EXEC.

      *----------------------------------------------------------------*
      * LOAD FILE INTO TSQ (ONLY FIRST TIME)
      *----------------------------------------------------------------*
       LOAD-TSQ.
           IF EIBCALEN > 0
           MOVE 0 TO CA-TOTAL
           END-IF
           EXEC CICS DELETEQ TS
                QUEUE(WS-TSQ-NAME)
                RESP(WS-RESP)
           END-EXEC

           MOVE LOW-VALUES  TO  LOAN-ID
              EXEC CICS STARTBR
                              FILE('DTGETAG')
                              RIDFLD(LOAN-ID)
                              RESp(WS-RESP)
              END-EXEC
               EXEC CICS READNEXT
                            FILE('DTGETAG')
                            RIDFLD(LOAN-ID)
                            INTO(LOAN-REC)
                            RESP(WS-RESP)
               END-EXEC
           PERFORM VARYING WS-I FROM 1 BY 1 UNTIL EOF = 'Y'
             IF WS-RESP = DFHRESP(NORMAL)
              MOVE CUST-ID      TO WS-CUSTID
              MOVE LOAN-ID     TO WS-LOANID
              MOVE NAME        TO WS-NAME
              MOVE STATUS1     TO WS-STATUS
              MOVE ACTAMT     TO WS-ACTAMT
              MOVE ZEROES TO WS-AMTPAID
              EXEC CICS WRITEQ TS
                   QUEUE(WS-TSQ-NAME)
                   FROM(WS-REC)
                   ITEM(WS-I)
                   MAIN
              END-EXEC

               EXEC CICS READNEXT
                            FILE('DTGETAG')
                            RIDFLD(LOAN-ID)
                            INTO(LOAN-REC)
                            RESP(WS-RESP)
               END-EXEC
               IF WS-RESP = DFHRESP(ENDFILE)
                   MOVE 'Y' TO EOF
                   EXEC CICS ENDBR
                             FILE('DTGETAG')
                             RESP(WS-RESP)
                   END-EXEC
               END-IF
              IF EIBCALEN > 0
              ADD 1 TO CA-TOTAL
              END-IF
              COMPUTE WS-TOTAL-TARGET = WS-TOTAL-TARGET + WS-ACTAMT
             END-IF
           END-PERFORM
           IF EIBCALEN > 0
           MOVE WS-TOTAL-TARGET TO CA-TOTAL-TARGET
           ELSE
           MOVE WS-TOTAL-TARGET TO TARGETO
           MOVE ZEROES TO TARGETO
           END-IF.
      *----------------------------------------------------------------*
      * DISPLAY PAGE (10 RECORDS)
      *----------------------------------------------------------------*
       DISPLAY-PARA.
           IF EIBCALEN > 0
           MOVE CA-INDEX TO WS-TEMP-INDEX
           MOVE WS-TOTAL-TARGET TO TARGETO
           MOVE CA-TOTAL-COLLECTED TO ACTUALO
           ELSE
           MOVE 1 TO WS-TEMP-INDEX
           END-IF
           PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > 10
                                            OR EOD = 'Y'
              EXEC CICS READQ TS
                   QUEUE(WS-TSQ-NAME)
                   ITEM(WS-TEMP-INDEX)
                   INTO(WS-REC)
                   RESP(WS-RESP)
              END-EXEC

              IF WS-RESP NOT = DFHRESP(NORMAL)
                 MOVE 'Y' TO EOD
              END-IF

              EVALUATE WS-I
                 WHEN 1
